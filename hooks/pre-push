#!/bin/bash
# Pre-push: when pushing a vX.Y.Z tag, require a matching CHANGELOG entry.
# Install with: ./scripts/install-hooks.sh
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "$local_ref" =~ refs/tags/ ]]; then
        TAG="${local_ref#refs/tags/}"
        if [[ "$TAG" =~ ^v[0-9]+\.[0-9]+\.[0-9]+(-.*)?$ ]]; then
            VER="${TAG#v}"
            if [ ! -f CHANGELOG.md ] || ! grep -q "## \[$VER\]" CHANGELOG.md; then
                echo "❌ CHANGELOG.md has no entry for $VER."
                echo "   Add one (or use scripts/create-release-tag.sh) before pushing $TAG."
                exit 1
            fi
        fi
    fi
done

exit 0
