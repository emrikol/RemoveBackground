#!/bin/bash
# Pre-commit: guard the prebuilt app icon, then enforce SwiftFormat + SwiftLint.
# Install with: ./scripts/install-hooks.sh
set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

staged() { git diff --cached --name-only --diff-filter=ACM; }

# Icon drift: the shipped icon is a pre-compiled RBGApp/AppIcon/Assets.car (CI can't run
# Xcode 26's actool). If main.icon changed but AppIcon/ didn't, the released icon goes
# stale — require regenerating it.
if staged | grep -q '^main\.icon/' && ! staged | grep -q '^RBGApp/AppIcon/'; then
    echo "❌ main.icon changed but RBGApp/AppIcon/ wasn't updated."
    echo "   Run: ./tools/compile-icon.sh   (needs Xcode 26)"
    echo "   then: git add RBGApp/AppIcon && re-commit."
    exit 1
fi

# SwiftFormat + SwiftLint — only when Swift files are staged.
if ! staged | grep -q '\.swift$'; then
    exit 0
fi

if command -v swiftformat >/dev/null 2>&1; then
    if ! swiftformat --lint RBGApp/Sources tools >/dev/null 2>&1; then
        echo "❌ SwiftFormat: sources need formatting."
        echo "   Run: swiftformat RBGApp/Sources tools"
        exit 1
    fi
else
    echo "⚠️  swiftformat not installed — skipping format check (brew install swiftformat)"
fi

if command -v swiftlint >/dev/null 2>&1; then
    if swiftlint lint --quiet 2>/dev/null | grep -q ' error:'; then
        echo "❌ SwiftLint reported errors:"
        swiftlint lint --quiet | grep ' error:'
        exit 1
    fi
else
    echo "⚠️  swiftlint not installed — skipping lint (brew install swiftlint)"
fi

exit 0
